  "keyFeatures": [
    "Multi-protocol credential issuance (Indy, W3C, OID4VC, SD-JWT, mDOC)",
    "Enterprise-grade multi-tenancy with dedicated or shared agents",
    "Bulk credential issuance with CSV import and template management",
    "Complete verification workflows with proof requests and presentation exchange",
    "Ecosystem management for multi-organization networks with auto-endorsement",
    "DIDComm-based connections with out-of-band invitations",
    "Multiple DID methods (did:indy, did:key, did:web, did:polygon)",
    "Webhook integration for real-time event notifications",
    "Role-based access control with organization and ecosystem roles",
    "Cloud wallet service for holder credential management",
    "X.509 certificate integration for credential signing",
    "Microservices architecture with NATS message broker"
  ],
  "publicApiSurface": [
    "POST /orgs - Create organization",
    "POST /orgs/:orgId/credentials/offer - Issue credential",
    "POST /orgs/:orgId/credentials/oob/offer - Out-of-band credential offer",
    "POST /orgs/:orgId/bulk/upload - Upload CSV for bulk issuance",
    "POST /orgs/:orgId/proofs - Send proof request",
    "POST /orgs/:orgId/proofs/:proofId/verify - Verify presentation",
    "POST /orgs/:orgId/connections - Create connection invitation",
    "POST /orgs/:orgId/schemas - Create schema",
    "POST /orgs/:orgId/credential-definitions - Create credential definition",
    "POST /agent/wallet/provision - Provision new agent",
    "POST /agent/wallet/did/create - Create DID",
    "POST /ecosystem - Create ecosystem",
    "POST /ecosystem/invitation - Invite member to ecosystem",
    "POST /orgs/:orgId/oid4vc/issuers - Create OID4VC issuer",
    "POST /orgs/:orgId/oid4vc/credentials/offers - Create credential offer",
    "POST /orgs/:orgId/oid4vp/verifiers - Create OID4VP verifier",
    "POST /auth/signup - User registration",
    "POST /auth/signin - User login",
    "GET /orgs/:orgId/credentials - Get credentials",
    "GET /orgs/:orgId/proofs - Get proof requests",
    "GET /orgs/:orgId/connections - Get connections"
  ]
